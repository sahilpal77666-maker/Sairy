<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sahil The System - Hunter App</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap');

        :root {
            --neon-blue: #00f3ff;
            --dark-bg: #090a0f;
            --card-bg: rgba(16, 20, 30, 0.85);
            --danger: #ff003c;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Share Tech Mono', monospace;
        }

        body {
            background-color: var(--dark-bg);
            background-image: 
                linear-gradient(rgba(0, 243, 255, 0.05) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 243, 255, 0.05) 1px, transparent 1px);
            background-size: 30px 30px;
            color: #fff;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            padding: 20px;
            overflow-x: hidden;
        }

        h1, h2, h3 {
            font-family: 'Orbitron', sans-serif;
            color: var(--neon-blue);
            text-shadow: 0 0 10px rgba(0, 243, 255, 0.5);
            text-transform: uppercase;
        }

        /* Glitch Animation for System Title */
        .glitch {
            font-size: 2.8rem;
            position: relative;
            margin-bottom: 20px;
            text-align: center;
            letter-spacing: 5px;
            color: #fff;
            text-shadow: 0 0 15px var(--neon-blue), 0 0 30px #0051ff;
        }

        /* Screens */
        .screen {
            width: 100%;
            max-width: 800px;
            display: none;
            animation: fadeIn 0.5s ease-in-out;
        }

        .screen.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Form Styling */
        .reg-box {
            background: var(--card-bg);
            border: 2px solid var(--neon-blue);
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0, 243, 255, 0.2);
        }

        .input-group {
            margin-bottom: 20px;
            display: flex;
            flex-direction: column;
        }

        label {
            color: var(--neon-blue);
            margin-bottom: 5px;
            font-weight: bold;
        }

        input[type="text"], input[type="date"], input[type="file"] {
            background: rgba(0,0,0,0.5);
            border: 1px solid var(--neon-blue);
            padding: 10px;
            color: #fff;
            font-family: 'Share Tech Mono', monospace;
            border-radius: 5px;
            outline: none;
        }

        button.sys-btn {
            background: transparent;
            color: var(--neon-blue);
            border: 2px solid var(--neon-blue);
            padding: 10px 20px;
            font-size: 1.2rem;
            font-family: 'Orbitron', sans-serif;
            cursor: pointer;
            width: 100%;
            transition: 0.3s;
            text-transform: uppercase;
            border-radius: 5px;
        }

        button.sys-btn:hover {
            background: var(--neon-blue);
            color: #000;
            box-shadow: 0 0 20px var(--neon-blue);
        }

        /* Real ID Card Design */
        .hunter-id-card {
            background: linear-gradient(135deg, #111b29, #090c15);
            border: 2px solid #333;
            border-radius: 15px;
            padding: 20px;
            display: flex;
            gap: 20px;
            box-shadow: 10px 10px 30px rgba(0,0,0,0.8), inset 0 0 20px rgba(0, 243, 255, 0.1);
            position: relative;
            overflow: hidden;
            margin-bottom: 20px;
        }

        .hunter-id-card::before {
            content: 'SAHIL THE SYSTEM';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-45deg);
            font-size: 3rem;
            color: rgba(255,255,255,0.03);
            font-family: 'Orbitron', sans-serif;
            white-space: nowrap;
            pointer-events: none;
        }

        .profile-pic-container {
            width: 150px;
            height: 180px;
            border: 3px solid var(--neon-blue);
            border-radius: 10px;
            overflow: hidden;
            background: #000;
            display: flex;
            justify-content: center;
            align-items: center;
            box-shadow: 0 0 15px rgba(0, 243, 255, 0.3);
        }

        .profile-pic-container img {
            width: 100%;
            height: 1